{
  "name": "bhd-marketplace",
  "private": true,
  "version": "1.0.0",
  "description": "BHD Oman multi-vendor marketplace (frontend + backend)",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run start:dev",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "build": "npm run build:backend && npm run build:frontend",
    "lint:frontend": "npm --prefix frontend run lint",
    "lint:backend": "npm --prefix backend run lint",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "test:frontend": "npm --prefix frontend run test",
    "test:backend": "npm --prefix backend run test",
    "test": "npm run test:backend && npm run test:frontend",
    "check:env": "node scripts/check-env.mjs",
    "smoke": "node scripts/smoke-buy-path.mjs",
    "fill:env-secrets": "node scripts/fill-env-secrets.mjs"
  }
}
