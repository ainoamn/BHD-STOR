# ============================================
# BHD Marketplace - Environment Configuration
# ============================================

# ─── Application ────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=/api
API_VERSION=v1
LOG_LEVEL=info
# Used in store QR deep links: {PUBLIC_APP_URL}/ar/s/{storeSerial}
PUBLIC_APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── Database ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=bhd_marketplace
DB_SCHEMA=public
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_MIGRATIONS_RUN=true

# ─── Redis ──────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ─── JWT Authentication ─────────────────────
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── AWS S3 (File Storage) ──────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-south-1
AWS_S3_BUCKET=bhd-marketplace-uploads

# ─── SMS Gateway ────────────────────────────
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=

# ─── Push Notifications ─────────────────────
FCM_SERVER_KEY=
APN_KEY_ID=
APN_TEAM_ID=

# ─── Payment Gateway ────────────────────────
PAYMENT_GATEWAY=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# LOGISTICS MODULE CONFIGURATION
# ============================================

# ─── Feature Flags ──────────────────────────
LOGISTICS_ENABLED=true
TRACKING_PUBLIC=true
AUTO_ASSIGN_ENABLED=true
GEOFENCE_ALERT_ENABLED=true

# ─── Pickup & Delivery ──────────────────────
DEFAULT_PICKUP_TIME=24
SAME_DAY_CUTOFF_HOUR=12

# ─── Routing ────────────────────────────────
MAX_ROUTE_STOPS=20
ROUTE_OPTIMIZATION_ENGINE=google

# ─── GPS Tracking ───────────────────────────
GPS_UPDATE_INTERVAL=30
GPS_PROVIDER=traccar
TRACCAR_URL=http://localhost:8082
TRACCAR_ADMIN_TOKEN=

# ─── Driver Management ──────────────────────
DRIVER_RATING_MIN=3.0
DRIVER_MAX_ACTIVE_SHIPMENTS=10
DRIVER_AUTO_OFFLINE_MINUTES=30

# ─── Notifications ──────────────────────────
SMS_TRACKING_UPDATES=true
PUSH_TRACKING_UPDATES=true
EMAIL_TRACKING_UPDATES=false

# ─── Pricing ────────────────────────────────
DEFAULT_CURRENCY=OMR
VAT_RATE=5.0
FUEL_SURCHARGE_ENABLED=true
INSURANCE_MIN_DECLARED_VALUE=100

# ─── WebSocket ──────────────────────────────
WS_PORT=3001
WS_NAMESPACE=/logistics
WS_CORS_ORIGIN=*
