    "bull": "^4.12.0",
    "cache-manager": "^5.3.2",
    "cache-manager-redis-store": "^3.0.1",
    "chromadb": "^1.8.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "csurf": "^1.11.0",
    "csv-parser": "^3.0.0",
    "date-fns": "^3.2.0",
    "dotenv": "^17.4.2",
    "ethers": "^6.17.0",
    "express-rate-limit": "^7.1.5",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.3.2",
    "joi": "^17.11.1",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.1.0",
    "lodash": "^4.17.21",
    "multer": "^1.4.5-lts.1",
    "nest-winston": "^1.9.4",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^6.9.8",
    "openai": "^4.24.7",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.2",
    "slugify": "^1.6.6",
    "stripe": "^14.12.0",
    "twilio": "^4.20.0",
