# ====================================================================
# BHD Oman Marketplace - Frontend Environment Variables
# ====================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# ====================================================================

# --------------------------------------------------------------------
# Core Application Configuration
# --------------------------------------------------------------------

# Base URL of the backend API server
# Used for all API requests from the frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Base URL of the frontend application
# Used for redirects, OG image generation, and canonical URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application environment
# Options: development, staging, production
NEXT_PUBLIC_APP_ENV=development

# Application name displayed in the browser tab and headers
NEXT_PUBLIC_APP_NAME="BHD Oman Marketplace"

# Application tagline shown in footer and meta descriptions
NEXT_PUBLIC_APP_TAGLINE="Oman's Premier E-Commerce Marketplace"

# Default locale for the application
# Options: ar (Arabic), en (English)
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# Available locales
NEXT_PUBLIC_LOCALES=ar,en

# Default currency for price display
# Options: OMR, USD, AED, SAR
NEXT_PUBLIC_DEFAULT_CURRENCY=OMR

# --------------------------------------------------------------------
# Authentication & Social Login
# --------------------------------------------------------------------

# NextAuth.js configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-nextauth-key-change-in-production

# Google OAuth 2.0 credentials
# Get from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple Sign In credentials
# Get from: https://developer.apple.com/account/resources/identifiers/list/serviceId
NEXT_PUBLIC_APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret

# Facebook Login credentials
# Get from: https://developers.facebook.com/apps
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Auth0 configuration (optional)
NEXT_PUBLIC_AUTH0_DOMAIN=your-auth0-domain.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# OTP Service
NEXT_PUBLIC_ENABLE_OTP_LOGIN=true

# --------------------------------------------------------------------
# Payment Gateway Configuration
# --------------------------------------------------------------------

# Stripe public key (for card payments)
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Thawani Pay public key (for Omani payments)
# Get from: https://uatcheckout.thawani.om/
NEXT_PUBLIC_THAWANI_PUBLIC_KEY=your-thawani-public-key

# Thawani Pay environment
# Options: uat (sandbox), production
NEXT_PUBLIC_THAWANI_ENV=uat

# OmanNet payment gateway public key
NEXT_PUBLIC_OMANNET_PUBLIC_KEY=your-omannet-public-key

# Apple Pay merchant ID
NEXT_PUBLIC_APPLE_PAY_MERCHANT_ID=merchant.com.bhd.marketplace

# Enable/disable payment methods
NEXT_PUBLIC_ENABLE_STRIPE=true
NEXT_PUBLIC_ENABLE_THAWANI=true
NEXT_PUBLIC_ENABLE_COD=true
NEXT_PUBLIC_ENABLE_BANK_TRANSFER=true

# --------------------------------------------------------------------
# AI & Smart Services
# --------------------------------------------------------------------

# OpenAI API key for AI chat assistant
# Get from: https://platform.openai.com/api-keys
NEXT_PUBLIC_OPENAI_API_KEY=sk-your-openai-api-key

# Enable AI chat assistant
NEXT_PUBLIC_ENABLE_AI_CHAT=true

# AI assistant welcome message
NEXT_PUBLIC_AI_WELCOME_MESSAGE="Welcome to BHD Oman! How can I help you today?"

# Pinecone vector database API key
# Get from: https://app.pinecone.io/
NEXT_PUBLIC_PINECONE_API_KEY=your-pinecone-api-key

# Pinecone index name for product search
NEXT_PUBLIC_PINECONE_INDEX_NAME=bhd-products

# Enable AI-powered product recommendations
NEXT_PUBLIC_ENABLE_AI_RECOMMENDATIONS=true

# Enable smart search with AI
NEXT_PUBLIC_ENABLE_SMART_SEARCH=true

# --------------------------------------------------------------------
# Cloudinary - Image & Video Management
# --------------------------------------------------------------------

# Cloudinary cloud name
# Get from: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name

# Cloudinary API key
NEXT_PUBLIC_CLOUDINARY_API_KEY=your-cloudinary-api-key

# Cloudinary upload preset for unsigned uploads
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=bhd_uploads

# Cloudinary base URL
NEXT_PUBLIC_CLOUDINARY_URL=https://res.cloudinary.com/your-cloud-name

# Enable image optimization via Cloudinary
NEXT_PUBLIC_ENABLE_CLOUDINARY_OPTIMIZATION=true

# --------------------------------------------------------------------
# Analytics & Tracking
# --------------------------------------------------------------------

# Google Analytics 4 measurement ID
# Get from: https://analytics.google.com/
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager container ID
NEXT_PUBLIC_GTM_CONTAINER_ID=GTM-XXXXXXX

# Facebook Pixel ID
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=your-facebook-pixel-id

# Hotjar site ID for heatmaps and recordings
# Get from: https://insights.hotjar.com/
NEXT_PUBLIC_HOTJAR_SITE_ID=your-hotjar-site-id

# Mixpanel project token
# Get from: https://mixpanel.com/project/settings
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# Enable/disable analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# --------------------------------------------------------------------
# Feature Flags
# --------------------------------------------------------------------

# Enable multi-vendor marketplace features
NEXT_PUBLIC_FEATURE_MARKETPLACE=true

# Enable subscription plans for sellers
NEXT_PUBLIC_FEATURE_SUBSCRIPTIONS=true

# Enable real-time chat between buyers and sellers
NEXT_PUBLIC_FEATURE_CHAT=true

# Enable auction/bidding functionality
NEXT_PUBLIC_FEATURE_AUCTIONS=false

# Enable flash sales
NEXT_PUBLIC_FEATURE_FLASH_SALES=true

# Enable referral program
NEXT_PUBLIC_FEATURE_REFERRALS=true

# Enable loyalty points system
NEXT_PUBLIC_FEATURE_LOYALTY=true

# Enable live streaming for sellers
NEXT_PUBLIC_FEATURE_LIVE_STREAMING=false

# Enable product comparison
NEXT_PUBLIC_FEATURE_COMPARISON=true

# Enable bulk purchase / B2B mode
NEXT_PUBLIC_FEATURE_B2B=false

# Enable dark mode toggle
NEXT_PUBLIC_FEATURE_DARK_MODE=true

# --------------------------------------------------------------------
# Maps & Location Services
# --------------------------------------------------------------------

# Google Maps API key
# Get from: https://developers.google.com/maps/documentation/javascript/get-api-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Enable map-based store locator
NEXT_PUBLIC_ENABLE_STORE_LOCATOR=true

# Default map center coordinates (Muscat, Oman)
NEXT_PUBLIC_DEFAULT_LAT=23.5859
NEXT_PUBLIC_DEFAULT_LNG=58.4059

# --------------------------------------------------------------------
# Notifications
# --------------------------------------------------------------------

# Enable web push notifications
NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true

# Firebase Cloud Messaging configuration
# Get from: https://console.firebase.google.com/
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=bhd-oman.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=bhd-oman
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=bhd-oman.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-firebase-vapid-key

# Pusher configuration for real-time notifications
NEXT_PUBLIC_PUSHER_APP_KEY=your-pusher-app-key
NEXT_PUBLIC_PUSHER_CLUSTER=mt1

# --------------------------------------------------------------------
# Shipping & Logistics
# --------------------------------------------------------------------

# Aramex API configuration
NEXT_PUBLIC_ARAMEX_API_KEY=your-aramex-api-key

# Enable shipping rate calculator
NEXT_PUBLIC_ENABLE_SHIPPING_CALCULATOR=true

# Enable order tracking
NEXT_PUBLIC_ENABLE_ORDER_TRACKING=true

# --------------------------------------------------------------------
# UI/UX Configuration
# --------------------------------------------------------------------

# Items per page for pagination
NEXT_PUBLIC_ITEMS_PER_PAGE=24

# Maximum products to compare
NEXT_PUBLIC_MAX_COMPARE_ITEMS=4

# Enable product quick view modal
NEXT_PUBLIC_ENABLE_QUICK_VIEW=true

# Enable image zoom on product hover
NEXT_PUBLIC_ENABLE_IMAGE_ZOOM=true

# Enable recently viewed products
NEXT_PUBLIC_ENABLE_RECENTLY_VIEWED=true

# Number of recently viewed items to save
NEXT_PUBLIC_RECENTLY_VIEWED_LIMIT=10

# --------------------------------------------------------------------
# Third-Party Services
# --------------------------------------------------------------------

# Tidio chat widget public key (alternative to built-in chat)
NEXT_PUBLIC_TIDIO_PUBLIC_KEY=your-tidio-public-key

# Zendesk support widget key
NEXT_PUBLIC_ZENDESK_KEY=your-zendesk-key

# reCAPTCHA site key
# Get from: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# hCaptcha site key (alternative to reCAPTCHA)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# --------------------------------------------------------------------
# Development & Debugging
# --------------------------------------------------------------------

# Enable demo/mock data mode (set true only when backend is unavailable)
# Production and real E2E tests MUST keep this false
NEXT_PUBLIC_DEMO_MODE=false


# Enable MSW (Mock Service Worker) for API mocking
NEXT_PUBLIC_ENABLE_MSW=false

# Log level for client-side logging
# Options: debug, info, warn, error
NEXT_PUBLIC_LOG_LEVEL=debug

# Enable React Query DevTools
NEXT_PUBLIC_ENABLE_RQ_DEVTOOLS=true

# API request timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT=30000
